<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Gauge.Interface.App"
        x:Class="Gauge.Interface.App.MainWindow"
        Title="Northstar Gauge Interface"
        Icon="/Assets/northstar-app-icon.png"
        Width="1180"
        Height="740"
        MinWidth="940"
        MinHeight="620"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        Background="{StaticResource BrandBackgroundBrush}">
  <Window.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{StaticResource BrandPanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#F8FAFB" />
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.icon">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#F2F5F6" />
    </Style>
    <Style Selector="Button.rowAction">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="42" />
      <Setter Property="Padding" Value="9" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.rowAction.saveAction">
      <Setter Property="Padding" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.rowAction.saveAction:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#F2F5F6" />
    </Style>
    <Style Selector="Button.tableHeader">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="0,3" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.tableHeader:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E9EEF0" />
    </Style>
    <Style Selector="ToggleButton.chartTool">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.chartTool:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="#F8ECEF" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}" />
    </Style>
    <Style Selector="ListBox.fileList > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.fileList > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F8ECEF" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource BrandMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.reviewValue">
      <Setter Property="FontFamily" Value="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>
  </Window.Styles>

  <Grid>
    <Grid IsVisible="{Binding IsSetupVisible}">
      <Border>
        <Border.Background>
          <ImageBrush Source="avares://Gauge.Interface.App/Assets/northstar-background-odin.jpg" Stretch="UniformToFill" Opacity="0.22" />
        </Border.Background>
      </Border>
      <Border Background="#EEFFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="34" Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="18">
          <Svg Path="/Assets/northstar-logo.svg" Width="330" Height="85" Stretch="Uniform" HorizontalAlignment="Left" />
          <TextBlock Text="Gauge Interface" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
          <StackPanel Spacing="8">
            <TextBlock Classes="label" Text="Serial Port" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPortOption}" MinHeight="40" />
              <Button Grid.Column="1" Classes="secondary" Content="Refresh" Command="{Binding RefreshPortsCommand}" />
            </Grid>
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Classes="label" Text="Default Output Folder" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding OutputDirectory}" MinHeight="40" />
              <Button Grid.Column="1" Classes="secondary" Content="Browse" Click="BrowseOutputDirectory_Click" />
            </Grid>
          </StackPanel>
          <Button Classes="primary" Content="Continue" Command="{Binding StartCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinHeight="46" />
          <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandMutedBrush}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid IsVisible="{Binding IsMainVisible}" RowDefinitions="Auto,*" Margin="18" RowSpacing="14">
      <Border Background="#FFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="18">
          <Svg Path="/Assets/northstar-logo.svg" Width="204" Height="46" Stretch="Uniform" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="Gauge Interface" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Text="{Binding DeviceSummary}" FontSize="13" Foreground="{StaticResource BrandMutedBrush}" />
          </StackPanel>
          <Border Grid.Column="2" Background="#F8FAFB" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8" VerticalAlignment="Center">
            <Grid ColumnDefinitions="12,Auto" ColumnSpacing="8">
              <Ellipse Width="12" Height="12" Fill="{Binding ConnectionBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
            </Grid>
          </Border>
          <Button Grid.Column="3" Classes="icon" Command="{Binding CancelOperationCommand}" IsVisible="{Binding CanCancelOperation}" ToolTip.Tip="Cancel current operation">
            <PathIcon Width="20" Height="20" Foreground="{StaticResource BrandPrimaryBrush}"
                      Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z" />
          </Button>
          <Button Grid.Column="4" Classes="icon" ToolTip.Tip="Settings">
            <PathIcon Width="22" Height="22" Foreground="{StaticResource BrandTextBrush}"
                      Data="M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37L19.54,5.9L17.05,6.9C16.54,6.5 15.98,6.17 15.37,5.92L15,3.27H11L10.63,5.92C10.02,6.17 9.46,6.5 8.95,6.9L6.46,5.9L4.46,9.37L6.57,11.02C6.53,11.34 6.5,11.67 6.5,12C6.5,12.33 6.53,12.66 6.57,12.98L4.46,14.63L6.46,18.1L8.95,17.1C9.46,17.5 10.02,17.83 10.63,18.08L11,20.73H15L15.37,18.08C15.98,17.83 16.54,17.5 17.05,17.1L19.54,18.1L21.54,14.63L19.43,12.98M13,15.5A3.5,3.5 0 1,1 13,8A3.5,3.5 0 0,1 13,15.5Z" />
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Serial Settings" Click="SerialSettings_Click" />
                <MenuItem Header="Gauge Settings" Click="GaugeSettings_Click" />
                <Separator />
                <MenuItem Header="Engineering Mode" Click="EngineeringMode_Click" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Border Classes="panel" IsVisible="{Binding IsDisconnectedVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="430">
          <StackPanel Spacing="14" HorizontalAlignment="Stretch">
            <Ellipse Width="54" Height="54" Fill="{StaticResource BrandPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Gauge disconnected" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandMutedBrush}" HorizontalAlignment="Center" />
            <Button Classes="secondary" Content="Settings" Command="{Binding OpenSettingsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          </StackPanel>
        </Border>

        <Grid IsVisible="{Binding IsFileTableVisible}" RowDefinitions="Auto,*" RowSpacing="10">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
            <TextBlock Text="Files" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" />
            <CheckBox Grid.Column="1" Content="Ignore small files" IsChecked="{Binding IgnoreSmallFiles}" Foreground="{StaticResource BrandMutedBrush}" VerticalAlignment="Center" />
            <Button Grid.Column="2" Classes="icon" Command="{Binding ReadFilesCommand}" ToolTip.Tip="Refresh file list">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M17.65,6.35C16.2,4.9 14.21,4 12,4C7.58,4 4,7.58 4,12C4,16.42 7.58,20 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" />
            </Button>
          </Grid>

          <Border Grid.Row="1" Classes="panel" Padding="0">
            <Grid RowDefinitions="Auto,*">
              <Border Background="#F5F7F8" Padding="20,11">
                <Grid ColumnDefinitions="88,*,78,112,170,148" ColumnSpacing="20">
                  <Button Classes="tableHeader" Click="SortByFileNumber_Click" ToolTip.Tip="Sort by file number">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="File" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <PathIcon Width="16" Height="16" Data="{Binding FileSortDirectionIcon}" Foreground="{StaticResource BrandPrimaryBrush}" IsVisible="{Binding IsFileNumberSortActive}" />
                      <PathIcon Width="16" Height="16" Data="M12,3L7,8H10V11H14V8H17L12,3M12,21L17,16H14V13H10V16H7L12,21Z" Foreground="#8A9298" IsVisible="{Binding IsFileNumberSortInactive}" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1" Classes="tableHeader" Click="SortByFileSize_Click" ToolTip.Tip="Sort by file size">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="Size" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <PathIcon Width="16" Height="16" Data="{Binding FileSortDirectionIcon}" Foreground="{StaticResource BrandPrimaryBrush}" IsVisible="{Binding IsFileSizeSortActive}" />
                      <PathIcon Width="16" Height="16" Data="M12,3L7,8H10V11H14V8H17L12,3M12,21L17,16H14V13H10V16H7L12,21Z" Foreground="#8A9298" IsVisible="{Binding IsFileSizeSortInactive}" />
                    </StackPanel>
                  </Button>
                  <TextBlock Grid.Column="2" Text="Interval" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="3" Text="Duration" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Grid>
              </Border>
              <ListBox Grid.Row="1" Classes="fileList" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}" BorderThickness="0" Background="#FFFFFF">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="20,13" BorderBrush="#E4E9EC" BorderThickness="0,0,0,1" MinHeight="66">
                      <Grid ColumnDefinitions="88,*,78,112,170,148" ColumnSpacing="20">
                        <TextBlock Text="{Binding Index}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" ColumnDefinitions="78,*" ColumnSpacing="14" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Size}" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" />
                          <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border Background="#DFE6E9" CornerRadius="4" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding SizePercent}" Height="8" BorderThickness="0" Foreground="{StaticResource BrandPrimaryBrush}" Background="Transparent" />
                          </Grid>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding Interval}" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" TextWrapping="NoWrap" />
                        <TextBlock Grid.Column="3" Text="{Binding Duration}" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" TextWrapping="NoWrap" />
                        <Grid Grid.Column="4" RowDefinitions="Auto,6" RowSpacing="7" VerticalAlignment="Center">
                          <TextBlock Text="{Binding RowStatus}" Foreground="{Binding StatusBrush}" TextTrimming="CharacterEllipsis" />
                          <Grid Grid.Row="1" Height="6" IsVisible="{Binding IsDownloading}">
                            <Border Background="#DFE6E9" CornerRadius="3" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="6" BorderThickness="0" Foreground="{StaticResource BrandPrimaryBrush}" Background="Transparent" />
                          </Grid>
                        </Grid>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                          <PathIcon Width="20" Height="20" IsVisible="{Binding ContainsAcousticData}" Foreground="{StaticResource BrandPrimaryBrush}" ToolTip.Tip="Contains acoustic packet data"
                                    Data="M1,9L3,11C8,6 16,6 21,11L23,9C16.93,2.93 7.07,2.93 1,9M9,17L12,20L15,17C13.35,15.35 10.65,15.35 9,17M5,13L7,15C9.76,12.24 14.24,12.24 17,15L19,13C15.14,9.14 8.86,9.14 5,13Z" />
                          <PathIcon Width="20" Height="20" IsVisible="{Binding ContainsRawAcousticData}" Foreground="{StaticResource BrandTextBrush}" ToolTip.Tip="Contains raw acoustic trace data"
                                    Data="M3,4H5V18H21V20H3V4M6,13H9L11,8L14,16L16,11H21V13H17.4L14,19L11,12L10,15H6V13Z" />
                          <Button Classes="rowAction" Click="FileAction_Click" IsEnabled="{Binding CanFileAction}" ToolTip.Tip="{Binding ActionToolTip}">
                            <PathIcon Width="22" Height="22" Data="{Binding ActionIcon}" Foreground="{Binding ActionBrush}" />
                          </Button>
                          <Button Classes="rowAction" Click="CancelFileDownload_Click" IsVisible="{Binding IsDownloading}" ToolTip.Tip="Cancel download">
                            <PathIcon Width="20" Height="20" Foreground="{StaticResource BrandPrimaryBrush}"
                                      Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z" />
                          </Button>
                          <Button Classes="rowAction" Click="RetryFileDownload_Click" IsVisible="{Binding IsRowRetryVisible}" ToolTip.Tip="Retry download">
                            <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandPrimaryBrush}"
                                      Data="M17.65,6.35C16.2,4.9 14.21,4 12,4C7.58,4 4,7.58 4,12C4,16.42 7.58,20 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" />
                          </Button>
                          <Button Classes="rowAction saveAction" Click="SaveRecord_Click" IsVisible="{Binding CanExportRecord}" ToolTip.Tip="Save record file">
                            <Svg Path="/Assets/ico-case.svg" Width="30" Height="26" Stretch="Uniform" />
                          </Button>
                          <Button Classes="rowAction saveAction" Click="SaveRaw_Click" IsVisible="{Binding CanExportRaw}" ToolTip.Tip="Save uncalibrated raw memory evidence">
                            <Svg Path="/Assets/ico-case.svg" Width="30" Height="26" Stretch="Uniform" />
                          </Button>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </Grid>

        <Grid IsVisible="{Binding IsGraphVisible}" RowDefinitions="Auto,*" RowSpacing="10">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <TextBlock Text="Review" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" />
            <Grid Grid.Column="1" Width="260" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,6" ColumnSpacing="8" RowSpacing="5" Margin="8,0" VerticalAlignment="Center" IsVisible="{Binding SelectedFile.IsDownloading}">
              <TextBlock Text="Downloading" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Classes="reviewValue" FontSize="12" Text="{Binding SelectedFile.ProgressText}" VerticalAlignment="Center" />
              <Grid Grid.Row="1" Grid.ColumnSpan="2" Height="6">
                <Border Background="#DFE6E9" CornerRadius="3" />
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding SelectedFile.ProgressPercent}" Height="6" BorderThickness="0" Foreground="{StaticResource BrandPrimaryBrush}" Background="Transparent" />
              </Grid>
              <Button Grid.Column="2" Grid.RowSpan="2" Classes="icon" Width="30" Height="30" Padding="6" Click="CancelSelectedDownload_Click" ToolTip.Tip="Cancel download">
                <PathIcon Width="18" Height="18" Foreground="{StaticResource BrandPrimaryBrush}"
                          Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z" />
              </Button>
            </Grid>
            <Button Grid.Column="2" Classes="icon" Click="RetrySelectedDownload_Click" IsVisible="{Binding SelectedFile.IsRetryAvailable}" ToolTip.Tip="Retry download">
              <PathIcon Width="20" Height="20" Foreground="{StaticResource BrandPrimaryBrush}"
                        Data="M17.65,6.35C16.2,4.9 14.21,4 12,4C7.58,4 4,7.58 4,12C4,16.42 7.58,20 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" />
            </Button>
            <ToggleButton x:Name="GraphCursorButton" Grid.Column="3" Classes="chartTool" IsChecked="True" Click="GraphCursor_Click" ToolTip.Tip="Inspect data">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M13,1H11V4.07C7.39,4.52 4.52,7.39 4.07,11H1V13H4.07C4.52,16.61 7.39,19.48 11,19.93V23H13V19.93C16.61,19.48 19.48,16.61 19.93,13H23V11H19.93C19.48,7.39 16.61,4.52 13,4.07V1M12,6C15.31,6 18,8.69 18,12C18,15.31 15.31,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6M12,9C10.34,9 9,10.34 9,12C9,13.66 10.34,15 12,15C13.66,15 15,13.66 15,12C15,10.34 13.66,9 12,9Z" />
            </ToggleButton>
            <ToggleButton x:Name="GraphZoomWindowButton" Grid.Column="4" Classes="chartTool" Click="GraphZoomWindow_Click" ToolTip.Tip="Zoom window">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M7,3H5C3.9,3 3,3.9 3,5V7H5V5H7V3M19,7V5C19,3.9 18.1,3 17,3H15V5H17V7H19M17,19H15V21H17C18.1,21 19,20.1 19,19V17H17V19M5,17H3V19C3,20.1 3.9,21 5,21H7V19H5V17M8,8V16H16V8H8Z" />
            </ToggleButton>
            <Button Grid.Column="5" Classes="icon" Click="GraphZoomIn_Click" ToolTip.Tip="Zoom in">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M9,3A6,6 0 0,1 15,9C15,10.61 14.37,12.09 13.34,13.19L13.71,13.56H14.79L20,18.77L18.77,20L13.56,14.79V13.71L13.19,13.34C12.09,14.37 10.61,15 9,15A6,6 0 1,1 9,3M8,6V8H6V10H8V12H10V10H12V8H10V6H8Z" />
            </Button>
            <Button Grid.Column="6" Classes="icon" Click="GraphZoomOut_Click" ToolTip.Tip="Zoom out">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M9,3A6,6 0 0,1 15,9C15,10.61 14.37,12.09 13.34,13.19L13.71,13.56H14.79L20,18.77L18.77,20L13.56,14.79V13.71L13.19,13.34C12.09,14.37 10.61,15 9,15A6,6 0 1,1 9,3M6,8V10H12V8H6Z" />
            </Button>
            <Button Grid.Column="7" Classes="icon" Click="GraphFit_Click" ToolTip.Tip="Fit all data">
              <PathIcon Width="21" Height="21" Foreground="{StaticResource BrandTextBrush}"
                        Data="M5,5H10V7H7V10H5V5M14,5H19V10H17V7H14V5M17,14H19V19H14V17H17V14M10,17V19H5V14H7V17H10Z" />
            </Button>
            <Button Grid.Column="8" Classes="icon" Click="SaveSelectedRecord_Click" IsVisible="{Binding SelectedFile.CanExportRecord}" ToolTip.Tip="Save record file">
              <Svg Path="/Assets/ico-case.svg" Width="30" Height="26" Stretch="Uniform" />
            </Button>
            <Button Grid.Column="9" Classes="icon" Command="{Binding BackToFilesCommand}" Click="BackToFiles_Click" ToolTip.Tip="Back to files">
              <PathIcon Width="22" Height="22" Foreground="{StaticResource BrandTextBrush}"
                        Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z" />
            </Button>
          </Grid>
          <Grid Grid.Row="1" ColumnDefinitions="290,*" ColumnSpacing="14">
            <Border Grid.Column="1" Classes="panel" Padding="8" ClipToBounds="True">
              <local:GaugeTrendChart x:Name="GaugeTrend" Data="{Binding ChartData}" CursorChanged="GaugeTrend_CursorChanged" />
            </Border>
            <Border Classes="panel">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="16">
                <Grid ColumnDefinitions="104,*" RowDefinitions="24,24,24,24,24,24" ColumnSpacing="14" RowSpacing="10">
                  <TextBlock Classes="label" Text="File" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="reviewValue" Text="{Binding ReviewFile}" />

                  <TextBlock Grid.Row="1" Classes="label" Text="Duration" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Classes="reviewValue" Text="{Binding JobDuration}" />

                  <TextBlock Grid.Row="2" Classes="label" Text="Interval" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Classes="reviewValue" Text="{Binding SelectedFile.Interval}" />

                  <TextBlock Grid.Row="3" Classes="label" Text="Samples" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Classes="reviewValue" Text="{Binding ReviewSampleCount}" />

                  <TextBlock Grid.Row="4" Classes="label" Text="Status" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Classes="reviewValue" Text="{Binding SelectedFile.ReviewStatus}" Foreground="{Binding SelectedFile.StatusBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SelectedFile.ReviewStatus}" />

                  <TextBlock Grid.Row="5" Classes="label" Text="Data Quality" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="5" Grid.Column="1" Classes="reviewValue" Text="{Binding SelectedFile.DataQualityDetail}" Foreground="{Binding SelectedFile.DataQualityBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SelectedFile.DataQualityDetail}" />
                </Grid>

                <Border Height="1" Background="{StaticResource BrandBorderBrush}" />

                <Grid ColumnDefinitions="104,*" RowDefinitions="24,24,24,24" ColumnSpacing="14" RowSpacing="10">
                  <TextBlock Classes="label" Text="Cursor Sample" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="reviewValue" Text="{Binding CursorSample}" />
                  <TextBlock Grid.Row="1" Classes="label" Text="Elapsed Time" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Classes="reviewValue" Text="{Binding CursorElapsed}" />
                  <TextBlock Grid.Row="2" Classes="label" Text="Pressure" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Classes="reviewValue" Text="{Binding CursorPressure}" Foreground="{StaticResource BrandPrimaryBrush}" />
                  <TextBlock Grid.Row="3" Classes="label" Text="Temperature" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Classes="reviewValue" Text="{Binding CursorTemperature}" Foreground="{StaticResource BrandAccentBrush}" />
                </Grid>

                <Border Height="1" Background="{StaticResource BrandBorderBrush}" />

                <Grid ColumnDefinitions="104,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="12">
                  <TextBlock Classes="label" Text="Pressure Min" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="reviewValue" Text="{Binding PressureMinimum}" />
                  <TextBlock Grid.Row="1" Classes="label" Text="Pressure Max" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Classes="reviewValue" Text="{Binding PressureMaximum}" />
                  <TextBlock Grid.Row="2" Classes="label" Text="Temperature Min" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Classes="reviewValue" Text="{Binding TemperatureMinimum}" />
                  <TextBlock Grid.Row="3" Classes="label" Text="Temperature Max" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Classes="reviewValue" Text="{Binding TemperatureMaximum}" />
                </Grid>
              </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <Grid IsVisible="{Binding IsSettingsOverlayVisible}" Background="#66000000" ZIndex="20">
      <Border IsVisible="{Binding IsGaugeSettingsVisible}" Background="#FFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Width="520" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,*" RowSpacing="18">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="Gauge Settings" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Text="{Binding ConnectionStatus}" Foreground="{Binding ConnectionBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="icon" Command="{Binding CloseSettingsOverlayCommand}" ToolTip.Tip="Close">
              <PathIcon Width="20" Height="20" Foreground="{StaticResource BrandTextBrush}"
                        Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z" />
            </Button>
          </Grid>
          <Grid Grid.Row="1" ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="12">
            <TextBlock Classes="label" Text="Gauge Type" />
            <TextBlock Grid.Column="1" Text="{Binding GaugeDeviceType}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="1" Classes="label" Text="Device Serial" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GaugeDeviceSerial}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="2" Classes="label" Text="Firmware" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GaugeFirmware}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="3" Classes="label" Text="PCB Type / Serial" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GaugePcb}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="4" Classes="label" Text="Measurement Interval" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GaugeMeasurementInterval}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="5" Classes="label" Text="Memory Mode" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding GaugeMemoryMode}" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Grid.Row="6" Classes="label" Text="Erase Status" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding GaugeEraseStatus}" Foreground="{StaticResource BrandTextBrush}" />
          </Grid>
        </Grid>
      </Border>

      <Border IsVisible="{Binding IsEngineeringModeVisible}" Background="#FFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Width="880" Height="560" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,*" RowSpacing="18">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="Engineering Mode" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Text="{Binding ConnectionStatus}" Foreground="{Binding ConnectionBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="icon" Command="{Binding CloseSettingsOverlayCommand}" ToolTip.Tip="Close">
              <PathIcon Width="20" Height="20" Foreground="{StaticResource BrandTextBrush}"
                        Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z" />
            </Button>
          </Grid>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" Margin="0,0,10,0">
              <Grid ColumnDefinitions="1.2*,0.8*,0.8*" ColumnSpacing="18">
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Serial Transport" />
                  <TextBlock Text="{Binding EngineeringTransport}" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Classes="label" Text="File Table" />
                  <TextBlock Text="{Binding EngineeringFileTable}" Foreground="{StaticResource BrandTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Classes="label" Text="Sensor Calibration" />
                  <TextBlock Text="{Binding EngineeringCalibration}" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
              </Grid>
              <Border Height="1" Background="{StaticResource BrandBorderBrush}" />
              <Grid ColumnDefinitions="0.9*,1.1*" ColumnSpacing="28">
                <StackPanel Spacing="5">
                  <TextBlock Classes="label" Text="Device Identity" />
                  <TextBlock Text="{Binding EngineeringDeviceDetails}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" FontSize="13" Foreground="{StaticResource BrandTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="label" Text="Communication Integrity" />
                    <TextBlock Grid.Column="1" Text="{Binding EngineeringCommunicationHealth}" FontWeight="SemiBold" Foreground="{Binding EngineeringCommunicationBrush}" />
                  </Grid>
                  <TextBlock Text="{Binding EngineeringCommunicationSession}" FontSize="13" Foreground="{StaticResource BrandMutedBrush}" />
                  <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="5">
                    <TextBlock Classes="label" Text="Transactions" />
                    <TextBlock Grid.Column="1" Text="{Binding EngineeringCommunicationTransactions}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" Foreground="{StaticResource BrandTextBrush}" />
                    <TextBlock Grid.Column="2" Classes="label" Text="Retries" />
                    <TextBlock Grid.Column="3" Text="{Binding EngineeringCommunicationRetries}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" Foreground="{StaticResource BrandTextBrush}" />
                    <TextBlock Grid.Row="1" Classes="label" Text="CRC errors" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EngineeringCommunicationCrcErrors}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" Foreground="{StaticResource BrandTextBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Classes="label" Text="Recovered" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding EngineeringCommunicationRecovered}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" Foreground="{StaticResource BrandTextBrush}" />
                    <TextBlock Grid.Row="2" Classes="label" Text="Failures" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EngineeringCommunicationFailures}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" Foreground="{Binding EngineeringCommunicationBrush}" />
                  </Grid>
                  <StackPanel Spacing="2">
                    <TextBlock Classes="label" Text="Last issue" />
                    <TextBlock Text="{Binding EngineeringCommunicationLastIssue}" FontSize="12" Foreground="{StaticResource BrandTextBrush}" TextWrapping="Wrap" MaxLines="2" />
                  </StackPanel>
                </StackPanel>
              </Grid>
              <Button Classes="secondary" Click="SaveSupportBundle_Click" HorizontalAlignment="Left" ToolTip.Tip="Save connection, gauge, file-table and calibration diagnostics">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="18" Height="18" Foreground="{StaticResource BrandTextBrush}"
                            Data="M19,9H15V3H9V9H5L12,16L19,9M5,18V20H19V18H5Z" />
                  <TextBlock Text="Save Support Bundle" VerticalAlignment="Center" />
                </StackPanel>
              </Button>

              <Border Height="2" Background="{StaticResource BrandPrimaryBrush}" Margin="0,4" />
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="4">
                <TextBlock Text="Firmware Update" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                <Button Grid.Column="1" Grid.RowSpan="2" Classes="secondary" Click="ChooseFirmware_Click" IsEnabled="{Binding CanChooseFirmware}" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Width="18" Height="18" Foreground="{StaticResource BrandTextBrush}"
                              Data="M10,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V8C22,6.9 21.1,6 20,6H12L10,4Z" />
                    <TextBlock Text="Choose HEX" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <TextBlock Grid.Row="1" Text="{Binding FirmwareImageName}" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              </Grid>
              <TextBlock Text="{Binding FirmwareImageSummary}" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" FontSize="12" Foreground="{StaticResource BrandMutedBrush}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="6">
                <TextBlock Classes="label" Text="Loader" />
                <TextBlock Grid.Column="1" Text="{Binding FirmwareLoaderDetails}" Foreground="{StaticResource BrandTextBrush}" />
                <TextBlock Grid.Row="1" Classes="label" Text="Status" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FirmwareStatus}" Foreground="{Binding FirmwareStatusBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
              </Grid>
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding FirmwareProgressPercent}" Height="8" IsVisible="{Binding IsFirmwareImageSelected}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                <TextBlock Text="Application flash is replaced; gauge memory and calibration are retained." Foreground="{StaticResource BrandMutedBrush}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="primary" Content="Program Firmware" Command="{Binding BeginFirmwareProgramCommand}" IsVisible="{Binding IsFirmwareNormalActionVisible}" />
                <Button Grid.Column="1" Classes="primary" Content="Recover Firmware" Command="{Binding BeginFirmwareRecoveryCommand}" IsVisible="{Binding IsFirmwareRecoveryActionVisible}" />
              </Grid>

              <Border IsVisible="{Binding IsFirmwareConfirmationVisible}" Background="#FFF3F5" Margin="-24,2,-14,0" Padding="24,16">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="14" RowSpacing="10">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Confirm Firmware Operation" FontWeight="SemiBold" Foreground="{StaticResource BrandPrimaryBrush}" />
                    <TextBlock Text="{Binding FirmwareConfirmationPrompt}" Foreground="{StaticResource BrandTextBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="secondary" Content="Cancel" Command="{Binding CancelFirmwareConfirmationCommand}" />
                    <Button Classes="primary" Content="{Binding FirmwareConfirmationAction}" Command="{Binding ConfirmFirmwareActionCommand}" />
                  </StackPanel>
                  <TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding FirmwareConfirmationText}" Watermark="Confirmation" FontFamily="avares://Gauge.Interface.App/Assets/Fonts#Cascadia Mono" />
                </Grid>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
