<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Gauge.Interface.App"
        x:Class="Gauge.Interface.App.MainWindow"
        Title="Northstar Gauge Interface"
        Width="1180"
        Height="740"
        MinWidth="940"
        MinHeight="620"
        Background="{StaticResource BrandBackgroundBrush}">
  <Window.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{StaticResource BrandPanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#F8FAFB" />
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource BrandMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </Window.Styles>

  <Grid>
    <Grid IsVisible="{Binding IsSetupVisible}">
      <Border>
        <Border.Background>
          <ImageBrush Source="avares://Gauge.Interface.App/Assets/northstar-background-odin.jpg" Stretch="UniformToFill" Opacity="0.22" />
        </Border.Background>
      </Border>
      <Border Background="#EEFFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="34" Width="460" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="18">
          <Image Source="avares://Gauge.Interface.App/Assets/northstar-logo.png" Width="330" Height="85" Stretch="Uniform" HorizontalAlignment="Left" />
          <TextBlock Text="Gauge Interface" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
          <StackPanel Spacing="8">
            <TextBlock Classes="label" Text="Serial Port" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPortOption}" MinHeight="40" />
              <Button Grid.Column="1" Classes="secondary" Content="Refresh" Command="{Binding RefreshPortsCommand}" />
            </Grid>
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Classes="label" Text="Default Output Folder" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding OutputDirectory}" MinHeight="40" />
              <Button Grid.Column="1" Classes="secondary" Content="Browse" Click="BrowseOutputDirectory_Click" />
            </Grid>
          </StackPanel>
          <Button Classes="primary" Content="Continue" Command="{Binding StartCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinHeight="46" />
          <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandMutedBrush}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid IsVisible="{Binding IsMainVisible}" RowDefinitions="Auto,*" Margin="18" RowSpacing="14">
      <Border Background="#FFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">
          <Image Source="avares://Gauge.Interface.App/Assets/northstar-logo.png" Width="190" Height="48" Stretch="Uniform" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="Gauge Interface" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Text="{Binding DeviceSummary}" FontSize="13" Foreground="{StaticResource BrandMutedBrush}" />
          </StackPanel>
          <Border Grid.Column="2" Background="#F8FAFB" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8" VerticalAlignment="Center">
            <Grid ColumnDefinitions="12,Auto" ColumnSpacing="8">
              <Ellipse Width="12" Height="12" Fill="{Binding ConnectionBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
            </Grid>
          </Border>
          <Button Grid.Column="3" Classes="secondary" Content="Settings" Command="{Binding OpenSettingsCommand}" />
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Border Classes="panel" IsVisible="{Binding IsDisconnectedVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="430">
          <StackPanel Spacing="14" HorizontalAlignment="Stretch">
            <Ellipse Width="54" Height="54" Fill="{StaticResource BrandPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Gauge disconnected" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandMutedBrush}" HorizontalAlignment="Center" />
            <Button Classes="secondary" Content="Settings" Command="{Binding OpenSettingsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          </StackPanel>
        </Border>

        <Grid IsVisible="{Binding IsFileTableVisible}" RowDefinitions="Auto,*" RowSpacing="12">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="Files" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Text="{Binding FileSummary}" Foreground="{StaticResource BrandMutedBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="secondary" Content="Read Files" Command="{Binding ReadFilesCommand}" VerticalAlignment="Center" />
            <Button Grid.Column="2" Classes="primary" Content="{Binding DownloadButtonText}" Command="{Binding DownloadSelectedCommand}" VerticalAlignment="Center" />
          </Grid>

          <Border Grid.Row="1" Classes="panel" Padding="0">
            <Grid RowDefinitions="Auto,*">
              <Border Background="{StaticResource BrandBackgroundBrush}" Padding="18,12">
                <Grid ColumnDefinitions="90,*,150,110" ColumnSpacing="14">
                  <TextBlock Text="File" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="Size" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2" Text="Status" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="3" Text="Graph" FontWeight="SemiBold" />
                </Grid>
              </Border>
              <ListBox Grid.Row="1" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}" BorderThickness="0" Background="#FFFFFF">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="18,12">
                      <Grid ColumnDefinitions="90,*,150,110" ColumnSpacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Index}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                          <TextBlock Text="{Binding Suggestion}" Foreground="{StaticResource BrandPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="7">
                          <TextBlock Text="{Binding Size}" Foreground="{StaticResource BrandTextBrush}" />
                          <Grid Grid.Row="1" Height="12">
                            <Border Background="#DDE6EA" CornerRadius="6" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding SizePercent}" Height="12" BorderThickness="0" Foreground="{StaticResource BrandPrimaryBrush}" Background="Transparent" />
                          </Grid>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding DownloadStatus}" Foreground="{StaticResource BrandMutedBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="3" Classes="secondary" Content="{Binding GraphStatus}" Click="FileGraph_Click" HorizontalAlignment="Stretch" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </Grid>

        <Grid IsVisible="{Binding IsGraphVisible}" RowDefinitions="Auto,*" RowSpacing="12">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
            <Button Classes="secondary" Content="Back" Command="{Binding BackToFilesCommand}" />
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Review" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Text="{Binding ReviewSummary}" Foreground="{StaticResource BrandMutedBrush}" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="{Binding LastCsvPath}" Foreground="{StaticResource BrandMutedBrush}" VerticalAlignment="Center" />
          </Grid>
          <Grid Grid.Row="1" ColumnDefinitions="*,220" ColumnSpacing="14">
            <Border Classes="panel" ClipToBounds="True">
              <local:GaugeTrendChart Samples="{Binding ChartSamples}" />
            </Border>
            <Border Grid.Column="1" Classes="panel">
              <StackPanel Spacing="18">
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Pressure Range" />
                  <TextBlock Text="{Binding PressureRange}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Temperature Range" />
                  <TextBlock Text="{Binding TemperatureRange}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Duration" />
                  <TextBlock Text="{Binding JobDuration}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Latest Pressure" />
                  <TextBlock Text="{Binding LatestPressure}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Latest Temperature" />
                  <TextBlock Text="{Binding LatestTemperature}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
