<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Gauge.Interface.App.MainWindow"
        Title="Gauge Interface"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="#F4F6F8">
  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="#5C6670" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="#17202A" />
      <Setter Property="FontSize" Value="34" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8DEE6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0B5CAD" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="20" RowSpacing="16">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
      <StackPanel Spacing="4">
        <TextBlock Text="Gauge Interface" FontSize="24" FontWeight="SemiBold" Foreground="#17202A" />
        <TextBlock Text="{Binding DeviceSummary}" Foreground="#53606C" FontSize="14" />
      </StackPanel>
      <Border Grid.Column="1" Background="#EAF2FB" BorderBrush="#BDD7F2" BorderThickness="1" CornerRadius="6" Padding="12,8">
        <TextBlock Text="{Binding Status}" Foreground="#17456F" FontWeight="SemiBold" />
      </Border>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="16">
      <StackPanel Spacing="16">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Connection" FontSize="17" FontWeight="SemiBold" Foreground="#17202A" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox ItemsSource="{Binding Ports}"
                        SelectedItem="{Binding SelectedPort}"
                        MinHeight="38" />
              <Button Grid.Column="1"
                      Content="Refresh"
                      Command="{Binding RefreshPortsCommand}"
                      MinHeight="38" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Output" FontSize="17" FontWeight="SemiBold" Foreground="#17202A" />
            <TextBox Text="{Binding OutputDirectory}" MinHeight="38" />
            <Button Classes="primary"
                    Content="Download Latest"
                    Command="{Binding DownloadLatestCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="44" />
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="8">
            <TextBlock Text="Last Export" FontSize="17" FontWeight="SemiBold" Foreground="#17202A" />
            <TextBlock Text="{Binding LastCsvPath}" TextWrapping="Wrap" Foreground="#53606C" />
          </StackPanel>
        </Border>
      </StackPanel>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="16">
        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
          <Border Classes="panel">
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Latest Temperature" />
              <TextBlock Classes="value" Text="{Binding LatestTemperature}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Classes="panel">
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Latest Pressure" />
              <TextBlock Classes="value" Text="{Binding LatestPressure}" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Row="1" Classes="panel" Padding="0">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Recent Samples" FontSize="17" FontWeight="SemiBold" Foreground="#17202A" Margin="18,18,18,10" />
            <Grid Grid.Row="1" RowDefinitions="Auto,*">
              <Border Background="#EEF2F6" Padding="18,10">
                <Grid ColumnDefinitions="80,*,*,*,90">
                  <TextBlock Text="Seq" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="Pressure psi" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2" Text="Temperature C" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="4" Text="CRC" FontWeight="SemiBold" />
                </Grid>
              </Border>
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Samples}"
                       BorderThickness="0"
                       Background="#FFFFFF">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="18,8">
                      <Grid ColumnDefinitions="80,*,*,*,90">
                        <TextBlock Text="{Binding Sequence}" />
                        <TextBlock Grid.Column="1" Text="{Binding Pressure}" />
                        <TextBlock Grid.Column="2" Text="{Binding Temperature}" />
                        <TextBlock Grid.Column="3" Text="{Binding Timestamp}" />
                        <TextBlock Grid.Column="4" Text="{Binding Crc}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
