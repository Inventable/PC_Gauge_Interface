<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Gauge.Interface.App"
        x:Class="Gauge.Interface.App.MainWindow"
        Title="Northstar Gauge Interface"
        Width="1240"
        Height="780"
        MinWidth="1040"
        MinHeight="680"
        Background="{StaticResource BrandBackgroundBrush}">
  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource BrandMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="FontSize" Value="32" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{StaticResource BrandPanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#F8FAFB" />
      <Setter Property="Foreground" Value="{StaticResource BrandTextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrandBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="16">
    <Border Background="#FFFFFF" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18,14">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="NORTHSTAR" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="25" FontWeight="Bold" />
          <Border Width="1" Height="32" Background="{StaticResource BrandBorderBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
          <TextBlock Text="Gauge Interface" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
          <TextBlock Text="{Binding DeviceSummary}" Foreground="{StaticResource BrandMutedBrush}" FontSize="14" />
        </StackPanel>
        <Border Grid.Column="2" Background="#F2FAF5" BorderBrush="#B8DEC7" BorderThickness="1" CornerRadius="6" Padding="14,9" VerticalAlignment="Center">
          <Grid ColumnDefinitions="10,Auto" ColumnSpacing="9">
            <Ellipse Width="10" Height="10" Fill="{StaticResource BrandAccentBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="380,*" ColumnSpacing="16">
      <StackPanel Spacing="16">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Connection" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox ItemsSource="{Binding Ports}"
                        SelectedItem="{Binding SelectedPort}"
                        MinHeight="38" />
              <Button Grid.Column="1"
                      Classes="secondary"
                      Content="Refresh"
                      Command="{Binding RefreshPortsCommand}"
                      MinHeight="38" />
            </Grid>
            <Button Classes="primary"
                    Content="Connect / Read Files"
                    Command="{Binding ReadFilesCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="46" />
            <Button Classes="secondary"
                    Content="Device Details"
                    Command="{Binding ToggleDeviceDetailsCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="38" />
          </StackPanel>
        </Border>

        <Border Classes="panel" IsVisible="{Binding ShowDeviceDetails}">
          <StackPanel Spacing="8">
            <TextBlock Text="Device Details" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Text="{Binding DeviceDetails}" TextWrapping="Wrap" Foreground="{StaticResource BrandMutedBrush}" />
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Output" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Classes="label" Text="Job Name" />
            <TextBox Text="{Binding JobName}" MinHeight="38" />
            <TextBlock Classes="label" Text="Folder" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding OutputDirectory}" MinHeight="38" />
              <Button Grid.Column="1"
                      Classes="secondary"
                      Content="Browse"
                      Click="BrowseOutputDirectory_Click"
                      MinHeight="38" />
            </Grid>
            <Button Classes="primary"
                    Content="Download Selected"
                    Command="{Binding DownloadSelectedCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="46" />
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
          <Border Classes="panel">
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Temperature" />
              <TextBlock Classes="value" Text="{Binding LatestTemperature}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Classes="panel">
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Pressure" />
              <TextBlock Classes="value" Text="{Binding LatestPressure}" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Classes="panel">
          <StackPanel Spacing="8">
            <TextBlock Text="Last Export" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
            <TextBlock Text="{Binding LastCsvPath}" TextWrapping="Wrap" Foreground="{StaticResource BrandMutedBrush}" />
          </StackPanel>
        </Border>
      </StackPanel>

      <Grid Grid.Column="1" RowDefinitions="*,230,190" RowSpacing="16">
        <Border Classes="panel" Padding="0">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto" Margin="18,18,18,10">
              <TextBlock Text="Gauge Files" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding FileSummary}" Foreground="{StaticResource BrandMutedBrush}" />
            </Grid>
            <Border Grid.Row="1" Background="{StaticResource BrandBackgroundBrush}" Padding="18,10">
              <Grid ColumnDefinitions="52,88,80,86,100,*,92,72" ColumnSpacing="10">
                <TextBlock Text="File" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="Address" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Rate" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Samples" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Size" FontWeight="SemiBold" />
                <TextBlock Grid.Column="5" Text="Relative size" FontWeight="SemiBold" />
                <TextBlock Grid.Column="6" Text="" />
                <TextBlock Grid.Column="7" Text="CRC" FontWeight="SemiBold" />
              </Grid>
            </Border>
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Files}"
                     SelectedItem="{Binding SelectedFile}"
                     BorderThickness="0"
                     Background="#FFFFFF">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Padding="18,9">
                    <Grid ColumnDefinitions="52,88,80,86,100,*,92,72" ColumnSpacing="10">
                      <TextBlock Text="{Binding Index}" />
                      <TextBlock Grid.Column="1" Text="{Binding Address}" />
                      <TextBlock Grid.Column="2" Text="{Binding Rate}" />
                      <TextBlock Grid.Column="3" Text="{Binding Samples}" />
                      <TextBlock Grid.Column="4" Text="{Binding Size}" />
                      <Grid Grid.Column="5" Height="12" VerticalAlignment="Center">
                        <Border Background="#DDE6EA" CornerRadius="6" />
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding SizePercent}"
                                     Height="12"
                                     BorderThickness="0"
                                     Foreground="{StaticResource BrandPrimaryBrush}"
                                     Background="Transparent" />
                      </Grid>
                      <TextBlock Grid.Column="6" Text="{Binding Suggestion}" Foreground="{StaticResource BrandPrimaryBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="7" Text="{Binding Crc}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Border Grid.Row="1" Classes="panel" Padding="0">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto" Margin="18,16,18,8">
              <TextBlock Text="Review" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding ReviewSummary}" Foreground="{StaticResource BrandMutedBrush}" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="*,170" ColumnSpacing="14" Margin="18,0,18,16">
              <Border BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                <local:GaugeTrendChart Samples="{Binding ChartSamples}" MinHeight="160" />
              </Border>
              <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                <StackPanel Spacing="3">
                  <TextBlock Classes="label" Text="Pressure Range" />
                  <TextBlock Text="{Binding PressureRange}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Spacing="3">
                  <TextBlock Classes="label" Text="Temperature Range" />
                  <TextBlock Text="{Binding TemperatureRange}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Spacing="3">
                  <TextBlock Classes="label" Text="Duration" />
                  <TextBlock Text="{Binding JobDuration}" Foreground="{StaticResource BrandTextBrush}" FontWeight="SemiBold" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="2" Classes="panel" Padding="0">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Downloaded Samples" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource BrandTextBrush}" Margin="18,18,18,10" />
            <Grid Grid.Row="1" RowDefinitions="Auto,*">
              <Border Background="{StaticResource BrandBackgroundBrush}" Padding="18,10">
                <Grid ColumnDefinitions="80,*,*,*,90">
                  <TextBlock Text="Seq" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="Pressure psi" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2" Text="Temperature C" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="4" Text="CRC" FontWeight="SemiBold" />
                </Grid>
              </Border>
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Samples}"
                       BorderThickness="0"
                       Background="#FFFFFF">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="18,8">
                      <Grid ColumnDefinitions="80,*,*,*,90">
                        <TextBlock Text="{Binding Sequence}" />
                        <TextBlock Grid.Column="1" Text="{Binding Pressure}" />
                        <TextBlock Grid.Column="2" Text="{Binding Temperature}" />
                        <TextBlock Grid.Column="3" Text="{Binding Timestamp}" />
                        <TextBlock Grid.Column="4" Text="{Binding Crc}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
